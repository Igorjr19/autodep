{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "autodep",
  "version": "0.1.0",
  "identifier": "com.autodep.app",
  "build": {
    "frontendDist": "../dist/autodep-v2/browser",
    "devUrl": "http://localhost:4210",
    "beforeDevCommand": "pnpm exec ng serve --port 4210",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "AutoDep",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "maximized": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": ["resources/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
